/* ===== 圆萌胶片 · 全局主题 ===== */
/* 暖调渐变 + 圆体加粗 + 大圆角 + 可爱细节 */

page {
  --c-bg-start: #FDF9F4;
  --c-bg-end: #FAF4EC;
  --c-card-start: #FFFDF9;
  --c-card-end: #FFFAF3;
  --c-card-border: #EAD9C4;
  --c-text: #4A3028;
  --c-text-soft: #6B4C3B;
  --c-text-light: #B8977E;
  --c-text-faint: #D4C0A8;
  --c-primary-start: #6B4C3B;
  --c-primary-end: #8B6914;
  --c-primary-light: rgba(139,105,20,0.08);
  --c-primary-glow: rgba(139,105,20,0.15);
  --c-tag-bg: rgba(139,105,20,0.08);
  --c-mood-1: #D4A0A0;
  --c-mood-2: #D4B896;
  --c-mood-3: #C8C0B8;
  --c-mood-4: #A8C4A0;
  --c-mood-5: #A0B8C4;
  --radius-sm: 14rpx;
  --radius-md: 22rpx;
  --radius-lg: 32rpx;
  --font-main: -apple-system, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;

  background: linear-gradient(180deg, var(--c-bg-start) 0%, var(--c-bg-end) 100%);
  font-family: var(--font-main);
  color: var(--c-text);
  font-size: 30rpx;
  line-height: 1.8;
  -webkit-font-smoothing: antialiased;
  letter-spacing: 1rpx;
}

.card {
  background: linear-gradient(135deg, var(--c-card-start), var(--c-card-end));
  border: 1rpx solid var(--c-card-border);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 1rpx 8rpx rgba(74,48,40,0.03), 0 4rpx 16rpx rgba(74,48,40,0.02);
}
