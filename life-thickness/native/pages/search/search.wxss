.search-page { padding: 24rpx; min-height: 100vh; background: #FAF7F2; }
.bar { display: flex; gap: 16rpx; align-items: center; }
.input { flex: 1; height: 80rpx; padding: 0 24rpx; background: #fff; border-radius: 48rpx; font-size: 30rpx; }
.btn { padding: 16rpx 32rpx; background: #8B7F6E; color: #fff; border-radius: 48rpx; font-size: 28rpx; }
.item { margin-bottom: 16rpx; }
.r-date { font-size: 26rpx; color: #8B7F6E; display: block; }
.r-text { font-size: 28rpx; line-height: 1.6; display: block; margin-top: 12rpx; color: #3D3D3D; }
.empty { text-align: center; padding: 80rpx 0; font-size: 28rpx; color: #9E9E9E; }
