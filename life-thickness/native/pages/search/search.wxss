.search-page { padding: 24rpx; min-height: 100vh; }
.bar { display: flex; gap: 14rpx; align-items: center; margin-bottom: 24rpx; }
.input { flex: 1; height: 80rpx; padding: 0 24rpx; background: linear-gradient(135deg, var(--c-card-start), var(--c-card-end)); border: 1rpx solid var(--c-card-border); border-radius: 48rpx; font-size: 28rpx; color: var(--c-text); }
.btn { padding: 16rpx 32rpx; background: linear-gradient(135deg, var(--c-primary-start), var(--c-primary-end)); color: #fff; border-radius: 48rpx; font-size: 26rpx; font-weight: 700; }
.item {
  margin-bottom: 14rpx; background: linear-gradient(135deg, var(--c-card-start), var(--c-card-end));
  border: 1rpx solid var(--c-card-border); border-radius: var(--radius-md); padding: 24rpx;
}
.r-date { font-size: 24rpx; color: var(--c-text-light); display: block; letter-spacing: 2rpx; }
.r-text { font-size: 28rpx; line-height: 1.7; display: block; margin-top: 10rpx; color: var(--c-text); font-weight: 500; }
.empty { text-align: center; padding: 80rpx 0; font-size: 26rpx; color: var(--c-text-faint); }
