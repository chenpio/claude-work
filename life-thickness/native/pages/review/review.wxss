.review-page { padding: 24rpx; min-height: 100vh; background: #FAF7F2; padding-bottom: 40rpx; }
.title { font-size: 40rpx; font-weight: 700; display: block; text-align: center; padding: 60rpx 0 24rpx; }
.gen-bar { text-align: center; margin-bottom: 24rpx; }
.gen-btn { display: inline-block; padding: 20rpx 48rpx; background: #8B7F6E; color: #fff; border-radius: 48rpx; font-size: 30rpx; }
.status { text-align: center; padding: 80rpx; font-size: 28rpx; color: #9E9E9E; }
.empty { text-align: center; padding: 40rpx 0; }
.empty-text { font-size: 28rpx; color: #9E9E9E; }
.card { background: #fff; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; }
.card-title { font-size: 30rpx; font-weight: 600; display: block; margin-bottom: 16rpx; }
.grid { display: flex; justify-content: space-around; }
.g-item { text-align: center; }
.num { font-size: 44rpx; font-weight: 700; color: #8B7F6E; display: block; }
.lab { font-size: 24rpx; color: #9E9E9E; }
.msg { font-size: 28rpx; line-height: 1.8; color: #3D3D3D; }
.sug { font-size: 28rpx; color: #3D3D3D; line-height: 2; }
.history { margin-top: 32rpx; }
.h-title { font-size: 30rpx; font-weight: 600; display: block; margin-bottom: 16rpx; }
.h-item { }
.h-range { font-size: 28rpx; font-weight: 600; display: block; }
.h-stat { font-size: 26rpx; color: #9E9E9E; margin-top: 8rpx; display: block; }
