.write-page { min-height: 100vh; background: var(--c-page); padding: 32rpx; }

/* 日期 + 天气行 */
.w-top-row { display: flex; align-items: center; margin-bottom: 28rpx; }
.w-date { font-size: 32rpx; font-weight: 700; color: var(--c-text); margin-right: 24rpx; }
.w-weathers { display: flex; gap: 8rpx; }
.w-weather { font-size: 32rpx; padding: 8rpx 12rpx; border-radius: 12rpx; opacity: 0.4; transition: opacity 0.2s; }
.w-weather.sel { opacity: 1; background: rgba(0,0,0,0.03); }

/* 心情行 */
.w-mood-row { display: flex; justify-content: center; gap: 28rpx; margin-bottom: 40rpx; }
.w-mood { padding: 16rpx 20rpx; border-radius: var(--radius-md); border: 2rpx solid transparent; transition: all 0.2s; }
.w-mood.sel { border-color: var(--c-primary-soft); background: var(--c-card); }
.mood-emoji { font-size: 44rpx; }

/* 正文 */
.w-content-box { margin-bottom: 32rpx; }
.w-content { width: 100%; min-height: 420rpx; font-size: 34rpx; line-height: 1.9; color: var(--c-text); }

/* 图片 */
.w-images { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 32rpx; }
.w-img-item { position: relative; }
.w-img { width: 164rpx; height: 164rpx; border-radius: var(--radius-sm); }
.w-img-del { position: absolute; top: -10rpx; right: -10rpx; width: 42rpx; height: 42rpx; background: rgba(0,0,0,0.55); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20rpx; }

/* 底部工具栏 */
.w-tools { display: flex; justify-content: space-around; padding: 24rpx 0; border-top: 1rpx solid var(--c-primary-soft); border-bottom: 1rpx solid var(--c-primary-soft); margin-bottom: 24rpx; }
.tool-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; padding: 12rpx 20rpx; }
.tool-icon { font-size: 36rpx; }
.tool-label { font-size: 22rpx; color: var(--c-text-light); max-width: 120rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* 标签 */
.w-tags { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 32rpx; }
.w-tag { padding: 14rpx 28rpx; border-radius: 40rpx; font-size: 26rpx; background: var(--c-primary-soft); color: var(--c-text); transition: all 0.15s; }
.w-tag.sel { background: var(--c-primary); color: #fff; }

/* 保存 */
.save-area { padding: 40rpx 0; }
.save-btn { background: var(--c-primary); color: #fff; text-align: center; padding: 30rpx; border-radius: 48rpx; font-size: 34rpx; font-weight: 600; letter-spacing: 4rpx; transition: transform 0.12s; }
.save-btn--press { transform: scale(0.97); }

.breath { height: 60rpx; }
