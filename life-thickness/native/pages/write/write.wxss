.write-page { min-height: 100vh; padding: 32rpx 28rpx; }

.w-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28rpx; }
.w-date { font-size: 30rpx; font-weight: 800; color: var(--c-text); letter-spacing: 2rpx; }
.w-weathers { display: flex; gap: 4rpx; }
.w-weather { font-size: 28rpx; padding: 6rpx 8rpx; border-radius: 10rpx; opacity: 0.35; transition: opacity 0.2s; }
.w-weather.sel { opacity: 1; background: var(--c-primary-light); }

.w-moods { display: flex; justify-content: center; gap: 20rpx; margin-bottom: 36rpx; }
.w-mood { font-size: 44rpx; padding: 14rpx 20rpx; border-radius: var(--radius-md); border: 2rpx solid transparent; transition: all 0.2s; }
.w-mood.sel { border-color: var(--c-primary-glow); background: var(--c-primary-light); transform: scale(1.08); }

.w-content-box { margin-bottom: 28rpx; }
.w-content {
  width: 100%; min-height: 380rpx; font-size: 32rpx; line-height: 2; color: var(--c-text);
  background: linear-gradient(135deg, var(--c-card-start), var(--c-card-end));
  border: 1rpx solid var(--c-card-border); border-radius: var(--radius-md);
  padding: 28rpx; box-sizing: border-box;
}

.w-images { display: flex; flex-wrap: wrap; gap: 14rpx; margin-bottom: 28rpx; }
.w-img-item { position: relative; }
.w-img { width: 160rpx; height: 160rpx; border-radius: var(--radius-sm); }
.w-img-del { position: absolute; top: -10rpx; right: -10rpx; width: 40rpx; height: 40rpx; background: rgba(74,48,40,0.6); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18rpx; }

.w-tools { display: flex; justify-content: center; gap: 40rpx; padding: 20rpx 0; border-top: 1rpx solid var(--c-card-border); border-bottom: 1rpx solid var(--c-card-border); margin-bottom: 24rpx; }
.tool-item { display: flex; flex-direction: column; align-items: center; gap: 4rpx; padding: 8rpx 16rpx; }
.tool-icon { font-size: 34rpx; }
.tool-label { font-size: 20rpx; color: var(--c-text-light); max-width: 100rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 600; }

.w-tags { display: flex; flex-wrap: wrap; gap: 14rpx; margin-bottom: 32rpx; }
.w-tag { padding: 12rpx 28rpx; border-radius: 36rpx; font-size: 26rpx; background: linear-gradient(160deg, var(--c-card-start), var(--c-card-end)); border: 1rpx solid var(--c-card-border); color: var(--c-text); font-weight: 600; transition: all 0.15s; }
.w-tag.sel { background: linear-gradient(135deg, var(--c-primary-start), var(--c-primary-end)); color: #fff; border-color: transparent; }

.save-area { padding: 36rpx 0; display: flex; justify-content: center; }
.save-btn {
  width: 480rpx;
  background: linear-gradient(135deg, var(--c-primary-start), var(--c-primary-end));
  color: #FFFBF5; text-align: center; padding: 28rpx; border-radius: 48rpx;
  font-size: 32rpx; font-weight: 800; letter-spacing: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(139,105,20,0.2);
  transition: transform 0.12s;
}
.save-btn--press { transform: scale(0.96); }

.breath { height: 60rpx; }
