.write-page { padding: 24rpx; padding-bottom: 140rpx; min-height: 100vh; background: #FAF7F2; }
.field { margin-bottom: 36rpx; }
.label { font-size: 28rpx; font-weight: 500; color: #3D3D3D; display: block; margin-bottom: 16rpx; }
.val { font-size: 30rpx; color: #8B7F6E; border-bottom: 2rpx dashed #C4B5A5; padding: 8rpx 0; display: inline-block; }
.opts { display: flex; flex-wrap: wrap; gap: 16rpx; }
.opt { padding: 12rpx 24rpx; border-radius: 32rpx; font-size: 26rpx; background: #F5F0E8; color: #8B7F6E; }
.opt.sel { background: #8B7F6E; color: #fff; }
.moods { display: flex; justify-content: space-between; }
.mood { font-size: 44rpx; padding: 16rpx 24rpx; border-radius: 16rpx; border: 2rpx solid transparent; }
.mood.sel { border-color: #8B7F6E; background: #F5F0E8; }
.loc-row { display: flex; gap: 16rpx; align-items: center; }
.loc-input { flex: 1; height: 72rpx; font-size: 30rpx; border-bottom: 2rpx solid #ECECEC; padding: 8rpx 0; }
.loc-btn { padding: 16rpx 24rpx; background: #F5F0E8; color: #8B7F6E; border-radius: 32rpx; font-size: 26rpx; white-space: nowrap; }
.content { width: 100%; min-height: 300rpx; font-size: 32rpx; line-height: 1.8; color: #3D3D3D; }
.img-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.img-item { position: relative; }
.img-thumb { width: 160rpx; height: 160rpx; border-radius: 12rpx; }
.img-del { position: absolute; top: -8rpx; right: -8rpx; width: 40rpx; height: 40rpx; background: rgba(0,0,0,0.5); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; }
.img-add { width: 160rpx; height: 160rpx; border: 2rpx dashed #C4B5A5; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; }
.add-icon { font-size: 52rpx; color: #C4B5A5; }
.input { width: 100%; height: 72rpx; font-size: 30rpx; border-bottom: 2rpx solid #ECECEC; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; padding: 20rpx 32rpx; padding-bottom: 40rpx; background: rgba(250,247,242,0.95); z-index: 100; }
.save-btn { background: #8B7F6E; color: #fff; text-align: center; padding: 28rpx; border-radius: 48rpx; font-size: 34rpx; font-weight: 600; }
