<scroll-view class="write-page" scroll-y enhanced show-scrollbar="{{false}}">
  <!-- 日期+天气一行 -->
  <view class="w-top-row">
    <picker mode="date" value="{{date}}" bindchange="onDate">
      <text class="w-date">{{date}}</text>
    </picker>
    <view class="w-weathers">
      <text wx:for="{{weatherList}}" wx:key="*this" class="w-weather {{item.selected ? 'sel' : ''}}" bindtap="setWeather" data-idx="{{index}}">{{item.label}}</text>
    </view>
  </view>

  <!-- 心情 -->
  <view class="w-mood-row">
    <text wx:for="{{moodList}}" wx:key="v" class="w-mood {{item.selected ? 'sel' : ''}}" bindtap="setMood" data-idx="{{index}}">
      <text class="mood-emoji">{{item.e}}</text>
    </text>
  </view>

  <!-- 正文 -->
  <view class="w-content-box">
    <textarea class="w-content" value="{{content}}" placeholder="今天发生了什么？" placeholder-style="color:#C4BBB3;font-style:italic;" bindinput="onContent" auto-height focus="{{autoFocus}}" />
  </view>

  <!-- 图片 -->
  <view class="w-images" wx:if="{{images.length}}">
    <view wx:for="{{images}}" wx:key="fileId" class="w-img-item">
      <image src="{{item.url}}" mode="aspectFill" class="w-img" bindtap="previewImage" data-idx="{{index}}" />
      <view class="w-img-del" bindtap="delImage" data-idx="{{index}}">✕</view>
    </view>
  </view>

  <!-- 底部工具栏 -->
  <view class="w-tools">
    <view class="tool-item" bindtap="addImage">
      <text class="tool-icon">📷</text>
      <text class="tool-label">图片</text>
    </view>
    <view class="tool-item" bindtap="getLocation">
      <text class="tool-icon">📍</text>
      <text class="tool-label">{{location || '地点'}}</text>
    </view>
    <view class="tool-item">
      <text class="tool-icon">🏷️</text>
      <text class="tool-label">标签</text>
    </view>
  </view>

  <!-- 标签展开区 -->
  <view class="w-tags" wx:if="{{showTags}}">
    <text wx:for="{{allTags}}" wx:key="*this" class="w-tag {{item.selected ? 'sel' : ''}}" bindtap="toggleTag" data-idx="{{index}}">{{item.label}}</text>
  </view>

  <!-- 保存按钮 -->
  <view class="save-area">
    <view class="save-btn" bindtap="save" hover-class="save-btn--press">保存日记</view>
  </view>

  <view class="breath"></view>
</scroll-view>
