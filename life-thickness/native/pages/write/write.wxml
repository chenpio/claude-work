<view class="write-page">
  <view class="field">
    <text class="label">日期</text>
    <picker mode="date" value="{{date}}" bindchange="onDate">
      <text class="val">{{date}}</text>
    </picker>
  </view>
  <view class="field">
    <text class="label">天气</text>
    <view class="opts">
      <text wx:for="{{weatherList}}" wx:key="*this" class="opt {{item.selected ? 'sel' : ''}}" bindtap="setWeather" data-idx="{{index}}">{{item.label}}</text>
    </view>
  </view>
  <view class="field">
    <text class="label">心情</text>
    <view class="moods">
      <text wx:for="{{moodList}}" wx:key="v" class="mood {{item.selected ? 'sel' : ''}}" bindtap="setMood" data-idx="{{index}}">{{item.e}}</text>
    </view>
  </view>
  <view class="field">
    <text class="label">地点</text>
    <view class="loc-row">
      <input class="loc-input" value="{{location}}" placeholder="点击右侧获取" bindinput="onLocation" />
      <view class="loc-btn" bindtap="getLocation">📍 定位</view>
    </view>
  </view>
  <view class="field">
    <text class="label">正文</text>
    <textarea class="content" value="{{content}}" placeholder="今天发生了什么？" bindinput="onContent" auto-height />
  </view>
  <view class="field">
    <text class="label">图片 ({{images.length}}/9)</text>
    <view class="img-list">
      <view wx:for="{{images}}" wx:key="fileId" class="img-item">
        <image src="{{item.url}}" mode="aspectFill" class="img-thumb" bindtap="previewImage" data-idx="{{index}}" />
        <view class="img-del" bindtap="delImage" data-idx="{{index}}">✕</view>
      </view>
      <view wx:if="{{images.length < 9}}" class="img-add" bindtap="addImage">
        <text class="add-icon">+</text>
      </view>
    </view>
  </view>
  <view class="field">
    <text class="label">标签</text>
    <view class="opts">
      <text wx:for="{{allTags}}" wx:key="*this" class="opt {{item.selected ? 'sel' : ''}}" bindtap="toggleTag" data-idx="{{index}}">#{{item.label}}</text>
    </view>
  </view>
  <view class="field">
    <text class="label">一句话</text>
    <input class="input" value="{{oneLine}}" placeholder="用一句话概括今天" bindinput="onOneLine" maxlength="50" />
  </view>
  <view class="bottom-bar">
    <view class="save-btn" bindtap="save">保存日记</view>
  </view>
</view>
