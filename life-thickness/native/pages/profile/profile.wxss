.profile-page { min-height: 100vh; padding-bottom: 40rpx; }

/* 头像昵称（微信原生自动显示） */
.p-hero { text-align: center; padding: 64rpx 0 20rpx; }
.p-avatar-open { display: block; width: 140rpx; height: 140rpx; margin: 0 auto; border-radius: 50%; overflow: hidden; border: 3rpx solid var(--c-card-border); }
.p-nick-open { display: block; font-size: 36rpx; font-weight: 800; margin-top: 18rpx; background: linear-gradient(135deg, var(--c-primary-start), var(--c-primary-end)); -webkit-background-clip: text; background-clip: text; color: transparent; }
.p-slogan { font-size: 24rpx; color: var(--c-text-faint); margin-top: 10rpx; display: block; letter-spacing: 2rpx; }

/* 统计 */
.p-stats { display: flex; justify-content: center; align-items: center; gap: 56rpx; padding: 20rpx 0 36rpx; }
.p-stat-item { text-align: center; }
.ps-num { font-size: 40rpx; font-weight: 800; display: block; background: linear-gradient(135deg, var(--c-primary-start), var(--c-primary-end)); -webkit-background-clip: text; background-clip: text; color: transparent; }
.ps-lab { font-size: 22rpx; color: var(--c-text-faint); margin-top: 4rpx; display: block; }
.p-stat-split { width: 1rpx; height: 40rpx; background: var(--c-card-border); }

/* 菜单 */
.p-menu { padding: 0 24rpx; }
.p-item {
  display: flex; align-items: center; gap: 18rpx; padding: 34rpx 28rpx;
  background: linear-gradient(135deg, var(--c-card-start), var(--c-card-end));
  border: 1rpx solid var(--c-card-border); border-radius: var(--radius-md);
  margin-bottom: 12rpx; transition: transform 0.12s;
  box-shadow: 0 1rpx 6rpx rgba(74,48,40,0.02);
}
.p-item--press { transform: scale(0.985); }
.p-item-icon { font-size: 34rpx; }
.p-item-text { flex: 1; font-size: 30rpx; color: var(--c-text); font-weight: 600; }
.p-item-arrow { font-size: 26rpx; color: var(--c-text-faint); }
