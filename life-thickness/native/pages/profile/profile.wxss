.profile-page { padding: 24rpx; min-height: 100vh; background: #FAF7F2; }
.user-card { text-align: center; padding: 60rpx 0 40rpx; }
.nickname { font-size: 36rpx; font-weight: 600; display: block; }
.slogan { font-size: 26rpx; color: #9E9E9E; margin-top: 8rpx; display: block; }
.menu { margin-top: 32rpx; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 36rpx 32rpx; background: #fff; border-radius: 16rpx; margin-bottom: 12rpx; font-size: 30rpx; }
.arrow { color: #C4B5A5; }
