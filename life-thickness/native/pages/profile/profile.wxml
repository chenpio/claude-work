<view class="profile-page">
  <view class="p-hero">
    <!-- 微信原生头像（无需授权直接显示） -->
    <open-data class="p-avatar-open" type="userAvatarUrl" />
    <!-- 微信原生昵称 -->
    <open-data class="p-nick-open" type="userNickName" />

    <!-- 保存过的资料（优先显示） -->
    <text wx:if="{{savedNickName}}" class="p-slogan">记录人生的长度，沉淀生活的厚度</text>
    <text wx:else class="p-slogan">👆 点击上方可更换头像和昵称</text>
  </view>

  <view class="p-stats">
    <view class="p-stat-item"><text class="ps-num">{{diaryCount}}</text><text class="ps-lab">日记</text></view>
    <view class="p-stat-split"></view>
    <view class="p-stat-item"><text class="ps-num">{{reviewCount}}</text><text class="ps-lab">复盘</text></view>
  </view>

  <view class="p-menu">
    <view class="p-item" bindtap="go" data-url="/pages/timeline/timeline" hover-class="p-item--press">
      <text class="p-item-icon">📅</text><text class="p-item-text">时间轴</text><text class="p-item-arrow">→</text>
    </view>
    <view class="p-item" bindtap="go" data-url="/pages/search/search" hover-class="p-item--press">
      <text class="p-item-icon">🔍</text><text class="p-item-text">搜索日记</text><text class="p-item-arrow">→</text>
    </view>
    <view class="p-item" bindtap="go" data-url="/pages/settings/settings" hover-class="p-item--press">
      <text class="p-item-icon">⚙️</text><text class="p-item-text">设置</text><text class="p-item-arrow">→</text>
    </view>
    <view class="p-item" bindtap="doExport" hover-class="p-item--press">
      <text class="p-item-icon">📥</text><text class="p-item-text">导出数据</text><text class="p-item-arrow">→</text>
    </view>
  </view>
</view>
