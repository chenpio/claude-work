<view class="profile-page">
  <view class="p-hero">
    <text class="p-name">人生厚度</text>
    <text class="p-desc">记录人生的长度，沉淀生活的厚度</text>
  </view>

  <view class="p-menu">
    <view class="p-item" bindtap="go" data-url="/pages/timeline/timeline" hover-class="p-item--press">
      <text class="p-item-icon">📅</text>
      <text class="p-item-text">时间轴</text>
      <text class="p-item-arrow">→</text>
    </view>
    <view class="p-item" bindtap="go" data-url="/pages/search/search" hover-class="p-item--press">
      <text class="p-item-icon">🔍</text>
      <text class="p-item-text">搜索日记</text>
      <text class="p-item-arrow">→</text>
    </view>
    <view class="p-item" bindtap="go" data-url="/pages/settings/settings" hover-class="p-item--press">
      <text class="p-item-icon">⚙️</text>
      <text class="p-item-text">设置</text>
      <text class="p-item-arrow">→</text>
    </view>
    <view class="p-item" bindtap="doExport" hover-class="p-item--press">
      <text class="p-item-icon">📥</text>
      <text class="p-item-text">导出数据</text>
      <text class="p-item-arrow">→</text>
    </view>
  </view>
</view>
