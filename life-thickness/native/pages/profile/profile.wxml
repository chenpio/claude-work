<view class="profile-page">
  <!-- 用户信息区 -->
  <view class="p-hero">
    <view class="p-avatar-box">
      <image wx:if="{{avatarUrl}}" class="p-avatar" src="{{avatarUrl}}" mode="aspectFill" />
      <view wx:else class="p-avatar-empty">👤</view>
    </view>
    <view class="p-auth" wx:if="{{!hasProfile}}">
      <button class="auth-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">点击授权头像</button>
      <input class="nick-input" type="nickname" value="{{nickName}}" placeholder="你的昵称" bindinput="onNickInput" />
      <view class="save-profile-btn" bindtap="saveProfile">完成设置</view>
    </view>
    <view wx:else>
      <text class="p-nick">{{nickName || '人生厚度'}}</text>
      <text class="p-slogan">记录人生的长度，沉淀生活的厚度</text>
    </view>
  </view>

  <!-- 统计 -->
  <view class="p-stats" wx:if="{{hasProfile}}">
    <view class="p-stat-item">
      <text class="ps-num">{{diaryCount}}</text>
      <text class="ps-lab">日记</text>
    </view>
    <view class="p-stat-split"></view>
    <view class="p-stat-item">
      <text class="ps-num">{{totalWords}}</text>
      <text class="ps-lab">字</text>
    </view>
    <view class="p-stat-split"></view>
    <view class="p-stat-item">
      <text class="ps-num">{{reviewCount}}</text>
      <text class="ps-lab">复盘</text>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="p-menu">
    <view class="p-item" bindtap="go" data-url="/pages/timeline/timeline" hover-class="p-item--press">
      <text class="p-item-icon">📅</text>
      <text class="p-item-text">时间轴</text>
      <text class="p-item-arrow">→</text>
    </view>
    <view class="p-item" bindtap="go" data-url="/pages/search/search" hover-class="p-item--press">
      <text class="p-item-icon">🔍</text>
      <text class="p-item-text">搜索日记</text>
      <text class="p-item-arrow">→</text>
    </view>
    <view class="p-item" bindtap="go" data-url="/pages/settings/settings" hover-class="p-item--press">
      <text class="p-item-icon">⚙️</text>
      <text class="p-item-text">设置</text>
      <text class="p-item-arrow">→</text>
    </view>
    <view class="p-item" bindtap="doExport" hover-class="p-item--press">
      <text class="p-item-icon">📥</text>
      <text class="p-item-text">导出数据</text>
      <text class="p-item-arrow">→</text>
    </view>
  </view>
</view>
