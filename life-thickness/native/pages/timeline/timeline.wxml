<view class="tl-page">
  <text class="title">时间轴</text>
  <view class="calendar">
    <view class="cal-hd"><text bindtap="prev">←</text><text>{{year}}年{{month}}月</text><text bindtap="next">→</text></view>
    <view class="days">
      <text wx:for="{{days}}" wx:key="idx" class="day {{item.hasDiary ? 'has' : ''}} {{item.isToday ? 'today' : ''}}" bindtap="goDay" data-date="{{item.date}}">{{item.day}}</text>
    </view>
  </view>
  <view class="tm" bindtap="random">⏳ 时光机</view>
</view>
